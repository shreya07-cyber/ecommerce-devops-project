services:
  - type: web
    name: ecommerce-devops-project
    env: python
    buildCommand: "pip install -r requirements.txt"
    startCommand: "gunicorn demo_ecommerce.app:app --bind 0.0.0.0:$PORT"
    envVars:
      - key: FLASK_ENV
        value: production
      - key: SECRET_KEY
        generateValue: true
